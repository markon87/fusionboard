# Copy this file to .env and replace with your actual values

# Syncfusion License Key
# Get your license key from: https://www.syncfusion.com/account/manage-license/download
VITE_SYNCFUSION_LICENSE_KEY=your_syncfusion_license_key_here

# App Configuration
VITE_APP_NAME=FusionBoard
VITE_APP_VERSION=1.0.0

# API Configuration
VITE_API_URL=http://localhost:3001
VITE_API_TIMEOUT=10000

# Environment
VITE_NODE_ENV=development

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_EXPORT=true
VITE_ENABLE_FILTERS=true

# Theme Configuration
VITE_DEFAULT_THEME=material